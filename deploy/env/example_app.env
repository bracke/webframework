# Example environment for the example_app launcher.
# Copy this file into /etc/webframework/example_app.env and adjust values.

PROJECT_ROOT=/home/USER/Projekte/Ada/webframework
EXAMPLE_APP_BIN=$PROJECT_ROOT/example_app/bin/example_app

# Keep arguments explicit and reviewable. Add flags only when needed.
EXAMPLE_APP_ARGS='--production --host 0.0.0.0 --port 8081 --secure-cookies --log-level info'
