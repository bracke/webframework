with "../../project_tools/project_tools.gpr";
with "../../terminal_styles/terminal_styles.gpr";
with "../webframework.gpr";

project Webframework_Cli is
   for Source_Dirs use ("src");
   for Object_Dir use "obj";
   for Exec_Dir use "bin";
   for Main use ("webframework.adb");

   package Compiler is
      for Default_Switches ("Ada") use
        ("-gnat2022", "-gnata", "-gnatwe", "-gnatyM120");
   end Compiler;
end Webframework_Cli;
